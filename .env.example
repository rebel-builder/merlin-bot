# Merlin Configuration
# Copy this to .env and fill in your values

# Camera credentials (required)
MERLIN_CAMERA_PASS=your_camera_password_here
MERLIN_CAMERA_IP=192.168.1.26
MERLIN_CAMERA_USER=admin

# Network (Tailscale IPs or LAN IPs)
MERLIN_PI_HOST=100.87.156.70

# Ollama model (optional, defaults shown)
MERLIN_MODEL=gemma4:e4b

# TTS voice (optional)
MERLIN_VOICE=am_fenrir

# Vision model (optional)
MERLIN_VISION_MODEL=mlx-community/nanoLLaVA-1.5-4bit

# ElevenLabs (only needed for generate_sounds.py, not core operation)
# ELEVENLABS_API_KEY=your_key_here
