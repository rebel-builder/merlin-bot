# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
*.egg

# Environment (SECRETS — never commit)
.env
.env.*
!.env.example

# Biometric data (PRIVATE — face photos, voice prints, embeddings)
faces/
voices/

# Briefing data (personal state, generated at runtime)
briefing/*.json

# Runtime state
state.json
/tmp/

# Sound files — include the sounds/ directory but not generated runtime audio
*.wav
*.mp3
!sounds/*.wav
!sounds/*.mp3

# Logs
logs/
*.log

# Models (too large for git)
models/*.onnx
training/merlin-gemma4-lora.gguf
training/venv/
training/mlx/

# macOS
.DS_Store
.stfolder/

# Windows build artifacts
windows/venv/
windows/*.onnx

# Claude worktrees
.claude/worktrees/
